{
	"name": "directus-extension-sql-query-panel",
	"version": "1.4.0",
	"type": "module",
	"description": "Insights Panel for viewing results for dynamic sql queries",
	"icon": "extension",
	"repository": {
		"type": "git",
		"url": "https://github.com/bcc-code/directus-sql-query-panel"
	},
	"author": {
		"name": "Gerard Lamusse"
	},
	"types": "types.d.ts",
	"files": [
		"dist",
		"README.md",
		"types.d.ts"
	],
	"directus:extension": {
		"host": "^10.1.14",
		"type": "bundle",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"entries": [
			{
				"type": "endpoint",
				"name": "insights",
				"source": "src/insights/index.ts"
			},
			{
				"type": "panel",
				"name": "sql-query",
				"source": "src/sql-query/index.ts"
			}
		]
	},
	"keywords": [
		"directus",
		"directus-extension",
		"directus-custom-bundle"
	],
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"add": "directus-extension add",
		"release-channel": "node ./scripts/release-channel.js"
	},
	"devDependencies": {
		"@directus/extensions": "3.0.23",
		"@directus/extensions-sdk": "^17.1.2",
		"@types/keyv": "^4.2.0",
		"@types/node": "^25.5.2",
		"lodash.debounce": "^4.0.8",
		"typescript": "^6.0.2",
		"vue": "^3.5.24"
	},
	"dependencies": {
		"@vueuse/core": "^14.2.1"
	}
}
